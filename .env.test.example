# Copy this file to .env.test.local for local test execution with real services.

# Required by server-side route modules used in tests
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key
UNSUBSCRIBE_TOKEN_SECRET=replace-with-a-long-random-secret

# Required for external weather smoke tests
OPENWEATHER_API_KEY=your-openweather-api-key
